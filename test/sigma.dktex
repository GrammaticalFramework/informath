\documentclass{article}
\usepackage{amsfonts}
\usepackage{amssymb}
\usepackage{amsmath}
\setlength\parindent{0pt}
\setlength\parskip{8pt}
\begin{document}
\newcommand{\meets}{\mathrel{\supset\!\!\!\subset}}
\newcommand{\notmeets}{\mathrel{\not\meets}}
\newcommand{\Complex}{\mathbb{C}}
\newcommand{\Integer}{\mathbb{Z}}
\newcommand{\Integral}[4]{\int_{ #1 }^{#2} #4 d #3}
\newcommand{\Natural}{\mathbb{N}}
\newcommand{\Rational}{\mathbb{Q}}
\newcommand{\Real}{\mathbb{R}}
\newcommand{\Summa}[4]{\sum_{ #3 = #1 }^{#2}{#4}}
\newcommand{\congruent}[3]{#1 \equiv #2 \, \mbox{mod} \, #3}
\newcommand{\divides}[2]{#1 \mid #2}
\newcommand{\infinity}{\infty}
\newcommand{\isempty}[1]{#1 = \emptyset}

The first sum:

\begin{verbatim}
theorem : Proof (Eq (sigma (nd 1) (nd 9) (i => i)) (nn 4 (nd 5))).
\end{verbatim}

\begin{dedukti}
theorem : Proof (Eq (sigma (nd 1) (nd 9) (i => i)) (nn 4 (nd 5))).
\end{dedukti}

The first integral:

\begin{verbatim}
theorem : Proof (Gt (integral (nd 0) (nd 1) (x => x)) 0).
\end{verbatim}

\begin{dedukti}
theorem : Proof (Gt (integral (nd 0) (nd 1) (x => x)) 0).
\end{dedukti}

The second sum:

\begin{verbatim}
theorem : (m : Nat) -> (n : Nat) -> Proof (and (Lt 0 m) (Lt m (minus n 1))) ->
  Proof (Gt (sigma m n (i => div 1 i)) (sigma (plus m 1) n (i => div 1 i)) ).
\end{verbatim}

\begin{dedukti}
theorem : (m : Nat) -> (n : Nat) -> Proof (and (Lt 0 m) (Lt m (minus n 1))) ->
  Proof (Gt (sigma m n (i => div 1 i)) (sigma (plus m 1) n (i => div 1 i)) ).
\end{dedukti}


\end{document}
