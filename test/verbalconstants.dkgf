Set : "set"
Type : "type"
Prop : "proposition"

#Elem : ElemKind

#Proof : ProofProp


false : FalseProp
and : CoreAndProp
or : CoreOrProp
if : CoreIfProp
forall : CoreAllProp
exists : CoreExistProp
not : CoreNotProp
iff : CoreIffProp

suchthat : SuchThatKind

Num : "number"
bool : "boolean"
List : "list of As"
Dig : "digit"
Nat : "natural number" | $\mathbb{N}$
Int : "integer" |  $\mathbb{Z}$
Rat : "rational number" | $\mathbb{Q}$
Real : "real number" |  $\mathbb{R}$
Complex : "complex number" | $\mathbb{C}$
Cardinal : "cardinal"
Eq : "X is equal to Y" | "X and Y are equal" | $#1 = #2$
Lt : Lt_Adj2 | $#1 < #2$
Gt : Gt_Adj2 | $#1 > #2$
Neq : "X is distinct from Y" | "X and Y are distinct" | $#1 \neq #2$
Leq : Leq_Adj2 | $#1 \leq #2$
Geq : Geq_Adj2 | $#1 \geq #2$
positive : "X is positive"
negative : "X is negative"
plus : "the sum of X and Y" | $#1 + #2$
minus : "the difference of X and Y" | $#1 - #2$
times : "the product of X and Y" | $#1 \times #2$
div : "the quotient of X and Y" | $\frac{#1}{#2}$
pow : "the power of X to Y" | $#1^{#2}$
neg : "the negation of X" | $-#1$
log : "the logarithm of X in Y" | $\log_{#2} #1$
sqrt : "the square root of X" | $\sqrt{#1}$
succ : "the successor of X"
abs : "the absolute value of X" | $\mid #1 \mid$
factorial : "the factorial of X" | $#1 !$
gcd : "the greatest common divisor of X and Y"
even : "X is even"
odd : "X is odd"
prime : "X is prime"
divisible : "X is divisible by Y"
divide : "X divides Y" | $#1 \mid $2$
divisor : "X is a divisor of Y"
converge : "X converges"
function : "function from As to Bs"
union : "the union of X and Y" | $#1 \cup #2$
intersection : "the intersection of X and Y" | $#1 \cap #2$
difference : "the difference of X and Y" | $#1 \setminus #2$
cartesian : "the cartesian product of X and Y" | $#1 \times #2$
powerset : "the powerset of X" | $\wp #1$
complement : "the complement of X" | $$
subset : "X is a proper subset of Y" | $#1 \subset #2$
subseteq : "X is a subset of Y" | $#1 \subseteq #2$
superset : "X is a proper superset of Y" | $#1 \supset #2$
superseteq : "X is a superset of Y" | $#1 \supset #2$
equalset : "X and Y are equal sets" | "X is equal to Y" | $#1 = #2$
notequalset : "X and Y are distinct sets" | "X is distinct from Y" | $#1 \neq #2$
element : "X is an element of Y" | $#1 \in #2$
notelement : notelement_Noun2 | $#1 \notin #2$
emptyset : "the empty set" | $\emptyset$
universeset : "the universal set" | $U$
congruent : "X is congruent to Y modulo Z" | $#1 \equiv #2 \, \mbox{mod} \, #3$
finite : "X is finite"
infinite : "X is infinite"
rational : "X is rational"
irrational : "X is irrational"
Polynomial : "polynomial"
degree : "the degree of X"
isRoot : "X is a root of Y"
cardinality : "the cardinality of X" | $\mid #1 \mid$
denumerable : "X is denumerable"
Vector : "vector"
length : "the length of X" | \Norm
norm : "the length of X" | "the norm of X" | $\mid #1 \mid$
square : "the square of X" | $#1 ^$
legendre : "the Legendre symbol of X and Y" | $\left(\frac{" "}{" "}\right)$
pi : pi_Name | $\pi$
Circle : "circle"
radius : "the radius of X"
area : "the area of X"
binomial : "the binomial coefficient of X over Y" | $\binom{#1}{#2}$
combinations : combinations_Fun2 | $C^{#1}_{#2}$
combinationsFromSet : combinationsFromSet_Fun2 | $C^{#1}_{#2}$
sin : "the sin of X" | $\sin #1$
cos : "the cosine of X" | $\cos #1$
tan : "the tangent of X" | $\tan #1$
arcsin : "the arcsine of X" | $\arcsin #1$
arccos : "the arccosine of X" | $\arccos #1$
arctan : "the arctangent of X" | $\arctan #1$
orthogonal : "X is orthogonal to Y" | "X is perpendicular to Y" | "X and Y are orthogonal" | "X and Y are perpendicular" | $#1 \perp #2$
angleBetween : "the angle between X and Y"
dotProduct : "the dot product of X and Y" | "the scalar product of X and Y" | $#1 \cdot #2$
vectorPlus : "the sum of X and Y" | "the resultant of X and Y" | $#1 + #2$
sphenic : "X is sphenic"
infinity : "the infinity" | $\infty$
sigma : NounBinder2 sum_Noun | $\sum_{ #3 = #1 }^{#2}{#4}$
integral : NounBinder2 (AdjNounNoun definite_Adj integral_Noun) | $\int_{ #1 }^{#2} #4 d #3$
ni : "X contains Y" | $#1 \ni #2$
disjoint : "X and Y are disjoint" | "X is disjoint from Y" | $#1 \notmeets #2$
empty : "X is empty" | $#1 = \emptyset$
inhabited : "X is inhabited"
sameParity : "X and Y have the same parity"


